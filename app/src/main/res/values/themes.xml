<resources>
    <!-- Base application theme using a system default to avoid dependency issues -->
    <style name="Theme.Inventarizace" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/graphite_core</item>
        <item name="android:statusBarColor">@color/graphite_core</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/graphite_core</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Inventarizace</item>
    </style>
</resources>
